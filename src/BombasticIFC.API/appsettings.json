{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=bombasticifcdb;Username=postgres;Password=REPLACE-IN-PRODUCTION"
  },
  "StoragePath": "/data/storage",
  "JwtSettings": {
    "Secret": "REPLACE-WITH-ENV-VAR-OR-SECRET-IN-PRODUCTION",
    "Issuer": "BombasticIFC",
    "Audience": "BombasticIFC-Client",
    "ExpirationInMinutes": "60"
  }
}
