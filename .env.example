# BombasticIFC — local development environment template
# Copy this file to .env and fill in real values.
# The .env file is gitignored and must never be committed.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=bombasticifcdb

# JWT secret — must be at least 32 characters
JWT_SECRET=changeme_use_openssl_rand_base64_32

# Connection string used by the API (references the variables above)
CONNECTION_STRING=Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
