# Docker Compose environment variables — copy to .env and fill in values before running.
# NEVER commit .env to git (it is gitignored).
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker compose -f docker-compose.coolify.yml up -d

# PostgreSQL credentials
DB_USER=postgres
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=bombasticifcdb

# JWT signing secret — minimum 32 characters, use a cryptographically random string
# Generate one with: openssl rand -hex 32
JWT_SECRET=changeme_use_a_long_random_secret_here_min_32_chars

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# File storage path inside the API container
STORAGE_PATH=/data/storage
