apiVersion: v1
kind: Secret
metadata:
  name: bombasticifccluster-secrets
  namespace: bombasticifccluster
type: Opaque
stringData:
  postgres-user: "postgres"
  postgres-password: "POSTGRES_PASSWORD"
  postgres-db: "bombasticifcdb"
  connection-string: "Host=postgres-service;Port=5432;Database=bombasticifcdb;Username=postgres;Password=POSTGRES_PASSWORD"
  jwt-secret: "YOURJWTSECRETKEY"
